<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MarkdownViewTest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="using:WinUI.Markdown.Controls"
    xmlns:pg="using:UnoPropertyGrid"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WinUI.Markdown Sample">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <CheckBox x:Name="ShowInputToggle" Content="Input" IsChecked="True" Checked="OnViewToggleChanged" Unchecked="OnViewToggleChanged" />
                <CheckBox x:Name="ShowPreviewToggle" Content="Preview" IsChecked="True" Checked="OnViewToggleChanged" Unchecked="OnViewToggleChanged" />
                <CheckBox x:Name="ShowPropsToggle" Content="Properties" IsChecked="True" Checked="OnViewToggleChanged" Unchecked="OnViewToggleChanged" />
            </StackPanel>

            <TextBlock
                x:Name="ActualModeText"
                Grid.Column="2"
                VerticalAlignment="Center"
                FontWeight="SemiBold" />
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="InputColumn" Width="360" MinWidth="200" />
                <ColumnDefinition x:Name="PreviewColumn" Width="*" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition x:Name="PropsColumn" Width="320" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="MarkdownEditor"
                AcceptsReturn="True"
                FontFamily="Cascadia Mono, Consolas"
                FontSize="13"
                Header="Markdown"
                HorizontalAlignment="Stretch"
                TextWrapping="Wrap"
                TextChanged="OnMarkdownChanged"
                VerticalAlignment="Stretch" />

            <Border
                x:Name="PreviewHost"
                Grid.Column="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16">
                <md:MarkdownView
                    x:Name="Viewer"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    LinkClicked="OnLinkClicked"
                    Rendered="OnMarkdownRendered" />
            </Border>

            <toolkit:GridSplitter
                x:Name="PropsSplitter"
                Grid.Column="2"
                Width="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                ResizeDirection="Columns" />

            <pg:PropertyGridControl
                x:Name="PropsPanel"
                Grid.Column="3"
                NameColumnWidth="160"
                ShowDescriptionPane="True" />
        </Grid>
    </Grid>
</Window>
