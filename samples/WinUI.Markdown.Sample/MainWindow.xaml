<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MarkdownViewTest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="using:WinUI.Markdown.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WinUI.Markdown Sample">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <CheckBox x:Name="ShowInputToggle" Content="Input" IsChecked="True" Checked="OnViewToggleChanged" Unchecked="OnViewToggleChanged" />
                <CheckBox x:Name="ShowPreviewToggle" Content="Preview" IsChecked="True" Checked="OnViewToggleChanged" Unchecked="OnViewToggleChanged" />
                <CheckBox x:Name="ShowPropsToggle" Content="Properties" IsChecked="True" Checked="OnViewToggleChanged" Unchecked="OnViewToggleChanged" />
            </StackPanel>

            <TextBlock
                x:Name="ActualModeText"
                Grid.Column="2"
                VerticalAlignment="Center"
                FontWeight="SemiBold" />
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="InputColumn" Width="360" />
                <ColumnDefinition x:Name="PreviewColumn" Width="*" />
                <ColumnDefinition x:Name="PropsColumn" Width="320" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="MarkdownEditor"
                AcceptsReturn="True"
                FontFamily="Cascadia Mono, Consolas"
                FontSize="13"
                Header="Markdown"
                HorizontalAlignment="Stretch"
                TextWrapping="Wrap"
                TextChanged="OnMarkdownChanged"
                VerticalAlignment="Stretch" />

            <Border
                x:Name="PreviewHost"
                Grid.Column="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16">
                <md:MarkdownView
                    x:Name="Viewer"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    LinkClicked="OnLinkClicked"
                    Rendered="OnMarkdownRendered" />
            </Border>

            <ScrollViewer
                x:Name="PropsPanel"
                Grid.Column="2"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="14">
                    <TextBlock Text="Control" FontSize="18" FontWeight="SemiBold" />

                    <ComboBox x:Name="RenderModeBox" Header="Render mode" SelectedIndex="0" SelectionChanged="OnRenderModeChanged">
                        <ComboBoxItem Content="Auto" />
                        <ComboBoxItem Content="Native" />
                        <ComboBoxItem Content="WebView2" />
                    </ComboBox>
                    <CheckBox x:Name="AllowFallbackToggle" Content="Allow WebView2 fallback" IsChecked="True" Checked="OnControlOptionChanged" Unchecked="OnControlOptionChanged" />
                    <TextBlock x:Name="FallbackReasonText" TextWrapping="Wrap" />

                    <ComboBox x:Name="ThemeBox" Header="Theme" SelectedIndex="0" SelectionChanged="OnThemeChanged">
                        <ComboBoxItem Content="Auto (WinUI)" />
                        <ComboBoxItem Content="WinUI Light" />
                        <ComboBoxItem Content="WinUI Dark" />
                        <ComboBoxItem Content="GitHub Light" />
                        <ComboBoxItem Content="GitHub Dark" />
                        <ComboBoxItem Content="Dracula" />
                    </ComboBox>

                    <TextBox x:Name="BodyFontBox" Header="Body font" Text="Segoe UI" TextChanged="OnThemeValueChanged" />
                    <TextBox x:Name="CodeFontBox" Header="Code font" Text="Cascadia Mono, Consolas" TextChanged="OnThemeValueChanged" />
                    <Slider x:Name="BodySize" Header="Body size" Minimum="11" Maximum="22" Value="14" ValueChanged="OnThemeSliderChanged" />

                    <TextBlock Text="Heading Sizes" FontWeight="SemiBold" />
                    <Slider x:Name="H1Size" Header="H1" Minimum="20" Maximum="48" Value="32" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="H2Size" Header="H2" Minimum="18" Maximum="42" Value="28" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="H3Size" Header="H3" Minimum="16" Maximum="36" Value="24" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="H4Size" Header="H4" Minimum="14" Maximum="32" Value="20" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="H5Size" Header="H5" Minimum="14" Maximum="28" Value="18" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="H6Size" Header="H6" Minimum="12" Maximum="24" Value="16" ValueChanged="OnThemeSliderChanged" />

                    <TextBlock Text="Heading Weights" FontWeight="SemiBold" />
                    <Slider x:Name="H1Weight" Header="H1 weight" Minimum="100" Maximum="900" StepFrequency="100" Value="600" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="H2Weight" Header="H2 weight" Minimum="100" Maximum="900" StepFrequency="100" Value="600" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="H3Weight" Header="H3 weight" Minimum="100" Maximum="900" StepFrequency="100" Value="600" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="H4Weight" Header="H4 weight" Minimum="100" Maximum="900" StepFrequency="100" Value="600" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="H5Weight" Header="H5 weight" Minimum="100" Maximum="900" StepFrequency="100" Value="600" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="H6Weight" Header="H6 weight" Minimum="100" Maximum="900" StepFrequency="100" Value="600" ValueChanged="OnThemeSliderChanged" />

                    <TextBlock Text="Heading Borders" FontWeight="SemiBold" />
                    <TextBox x:Name="HeadingBorderBox" Header="Heading border" Text="#50000000" TextChanged="OnThemeValueChanged" />
                    <Slider x:Name="H1BorderThickness" Header="H1 border thickness" Minimum="0" Maximum="4" Value="0" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="H2BorderThickness" Header="H2 border thickness" Minimum="0" Maximum="4" Value="0" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="HeadingBorderPadding" Header="Heading border padding" Minimum="0" Maximum="0.6" StepFrequency="0.05" Value="0" ValueChanged="OnThemeSliderChanged" />

                    <TextBlock Text="Spacing" FontWeight="SemiBold" />
                    <Slider x:Name="HeadingBefore" Header="Heading before" Minimum="0" Maximum="40" Value="16" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="HeadingAfter" Header="Heading after" Minimum="0" Maximum="24" Value="6" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="ParagraphSpacing" Header="Paragraph spacing" Minimum="0" Maximum="28" Value="8" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="BlockSpacing" Header="Block spacing" Minimum="0" Maximum="32" Value="10" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="ListSpacing" Header="List spacing" Minimum="0" Maximum="28" Value="8" ValueChanged="OnThemeSliderChanged" />

                    <TextBlock Text="Colors" FontWeight="SemiBold" />
                    <TextBox x:Name="BackgroundBox" Header="Background" Text="#FFFFFF" TextChanged="OnThemeValueChanged" />
                    <TextBox x:Name="ForegroundBox" Header="Foreground" Text="#111111" TextChanged="OnThemeValueChanged" />
                    <TextBox x:Name="CodeBackgroundBox" Header="Code background" Text="#14000000" TextChanged="OnThemeValueChanged" />
                    <TextBox x:Name="CodeForegroundBox" Header="Code foreground" Text="#24292F" TextChanged="OnThemeValueChanged" />
                    <TextBox x:Name="CodeBorderBox" Header="Code border" Text="#00000000" TextChanged="OnThemeValueChanged" />
                    <TextBox x:Name="LinkForegroundBox" Header="Link" Text="#005FB8" TextChanged="OnThemeValueChanged" />
                    <TextBox x:Name="BlockquoteAccentBox" Header="Blockquote accent" Text="#60789C" TextChanged="OnThemeValueChanged" />
                    <TextBox x:Name="BlockquoteBackgroundBox" Header="Blockquote background" Text="#08000000" TextChanged="OnThemeValueChanged" />
                    <TextBox x:Name="TableBorderBox" Header="Table border" Text="#50000000" TextChanged="OnThemeValueChanged" />
                    <TextBox x:Name="TableHeaderBackgroundBox" Header="Table header background" Text="#0A000000" TextChanged="OnThemeValueChanged" />
                    <TextBox x:Name="TableRowAlternateBackgroundBox" Header="Table alternate row" Text="#00000000" TextChanged="OnThemeValueChanged" />
                    <TextBox x:Name="HrStrokeBox" Header="Rule stroke" Text="#78000000" TextChanged="OnThemeValueChanged" />
                    <Slider x:Name="CodeBorderThickness" Header="Code border thickness" Minimum="0" Maximum="4" Value="0" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="CodeCornerRadius" Header="Code corner radius" Minimum="0" Maximum="18" Value="6" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="InlineCodeCornerRadius" Header="Inline code radius" Minimum="0" Maximum="12" Value="4" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="BlockquoteCornerRadius" Header="Blockquote radius" Minimum="0" Maximum="18" Value="0" ValueChanged="OnThemeSliderChanged" />
                    <Slider x:Name="MaxImageWidth" Header="Max image width" Minimum="120" Maximum="1200" Value="720" ValueChanged="OnThemeSliderChanged" />

                    <TextBox
                        x:Name="CustomCssBox"
                        AcceptsReturn="True"
                        Header="Custom CSS"
                        Height="120"
                        TextWrapping="Wrap"
                        TextChanged="OnThemeValueChanged" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
